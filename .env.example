# ============================================================
#  FlowMind — Environment Variables
#  1. Copy this file:   cp .env.example .env
#  2. Fill in values below
#  3. NEVER commit .env to git
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────
# Local install:  mongodb://localhost:27017/flowmind
# Atlas cloud:    mongodb+srv://user:pass@cluster.mongodb.net/flowmind
MONGODB_URI=mongodb://localhost:27017/flowmind

# ── JWT Auth ─────────────────────────────────────────────────
# Generate a secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Groq AI (FREE & FAST) ────────────────────────────────────
# Get your FREE key at: https://console.groq.com/keys
# Sign up → Dashboard → API Keys → Create API Key
# Free tier: 14,400 requests/day  |  30 req/min  |  $0 forever
# Model: llama-3.1-8b-instant  (ultra fast, great quality)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Email Notifications (OPTIONAL) ──────────────────────────
# If not set, the app works fine — email actions are just skipped
# Gmail: go to myaccount.google.com/security → App Passwords → create one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=FlowMind <your@gmail.com>

# ── Slack Notifications (OPTIONAL) ──────────────────────────
# If not set, the app works fine — Slack actions are just skipped
# Create webhook: api.slack.com/apps → Incoming Webhooks → Add to workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
